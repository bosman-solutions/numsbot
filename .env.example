# NumsBot environment variables
# Copy this to .env and fill in your values

# Required — Bot tab in Discord Developer Portal
DISCORD_TOKEN=your-bot-token-here

# Required — your Discord user ID (right-click your name → Copy User ID)
# Enable Developer Mode first: Settings → Advanced → Developer Mode
ADMIN_ID=your-discord-user-id-here

# Optional — enables Google Maps link enrichment on yolo nominations
# console.cloud.google.com → Places API (New) → free tier: 10k requests/month
GOOGLE_PLACES_API_KEY=

# Optional — log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
